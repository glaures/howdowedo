# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# docker-compose reads this file for both the `app` container (env_file) and for ${...} substitution.
# Values shown are local-dev defaults; the comments note what to change for production.

# --- Microsoft 365 / Entra ID ---
# Register an app at https://entra.microsoft.com -> App registrations.
# Redirect URI to configure there:
#   local:      http://localhost:8081/auth/callback
#   production: https://your-domain/auth/callback
AZURE_TENANT_ID=your-tenant-id-or-common
AZURE_CLIENT_ID=your-azure-application-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# --- Google (optional; enable the matching block in application-security.yml) ---
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- MySQL (matches docker-compose.yml) ---
# In production: pick strong, unique passwords. MYSQL_HOST is set to `db` inside compose automatically.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=howdowedo
MYSQL_USER=howdowedo
MYSQL_PASSWORD=howdowedo
MYSQL_ROOT_PASSWORD=root

# --- Public URL & mail (survey invitations) ---
# APP_BASE_URL must be the externally reachable URL; it is embedded in invitation links.
# Production example: https://surveys.your-domain
APP_BASE_URL=http://localhost:8081
MAIL_FROM=no-reply@howdowedo.local
MAIL_HOST=localhost
MAIL_PORT=1025
# For a real SMTP server, set credentials and enable auth/STARTTLS:
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true

# --- HTTP / reverse proxy (production) ---
# When the app runs behind an HTTPS-terminating reverse proxy (nginx, Traefik, ...):
#   FORWARD_HEADERS_STRATEGY=framework   # trust X-Forwarded-* so OAuth redirects use https
#   SESSION_COOKIE_SECURE=true           # only send the session cookie over HTTPS
FORWARD_HEADERS_STRATEGY=none
SESSION_COOKIE_SECURE=false

# --- Docker host port mappings (compose) ---
# APP_PORT: host port the app is published on. DB_BIND/DB_PORT: where MySQL is published; the default
# binds to localhost only, so the database is not exposed publicly in production.
APP_PORT=8081
DB_BIND=127.0.0.1
DB_PORT=3306

# --- Sessions (login persistence) ---
# Sessions are stored in MySQL and survive restarts. Defaults keep users signed in for 30 days.
# SESSION_TIMEOUT=30d
# SESSION_COOKIE_MAX_AGE=30d

# --- Survey seeding (optional) ---
# When true, a survey is created on startup from a tab-separated seed file. The seed file is optional
# and not part of the repository; if it is missing the seeder simply does nothing.
SEED_SURVEY=false
# SEED_SURVEY_FILE=seed/seed-survey.tsv

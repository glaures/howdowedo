# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Microsoft 365 / Entra ID (Expondo) ---
# Register an app at https://entra.microsoft.com -> App registrations.
# Redirect URI to configure there: http://localhost:8081/auth/callback
AZURE_TENANT_ID=your-tenant-id-or-common
AZURE_CLIENT_ID=your-azure-application-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# --- MySQL (matches docker-compose.yml) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=howdowedo
MYSQL_USER=howdowedo
MYSQL_PASSWORD=howdowedo

# --- Mail (survey invitations; defaults match a local MailHog on :1025) ---
APP_BASE_URL=http://localhost:8081
MAIL_FROM=no-reply@howdowedo.local
MAIL_HOST=localhost
MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false

# --- Google (optional; enable the matching block in application-security.yml) ---
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
